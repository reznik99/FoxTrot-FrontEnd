{
    "arrowParens": "avoid",
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 125,
    "tabWidth": 4,
    "useTabs": false,
    "plugins": ["@ianvs/prettier-plugin-sort-imports"],
    "importOrder": [
        "^react(-native)?(/.*)?$",
        "<THIRD_PARTY_MODULES>",
        "",
        "^~/(.*)$",
        "",
        "^[./]"
    ]
}
